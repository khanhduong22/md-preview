    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "debug.*",
    "filesystem.*"
  ],
  "window": {
    "title": "Markdown Viewer",
    "width": 800,
    "minWidth": 600,
    "height": 500,
    "minHeight": 400,
    "resizable": true,
    "maximize": false,
    "center": true
  },
  "modes": {
