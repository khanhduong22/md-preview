{
  "manifest_version": 3,
  "name": "2ndBrain - Premium Markdown Editor",
  "version": "1.0.0",
  "description": "A premium, glassmorphism-styled Markdown editor with advanced features for professionals.",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "default_title": "Open 2ndBrain"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "sidePanel"
  ]
}
